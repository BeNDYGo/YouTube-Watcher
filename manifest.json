{
  "manifest_version": 3,
  "name": "YouTube Temporary Playlist",
  "version": "7.6.3",
  "description": "Adds a temporary floating playlist on YouTube when A is held while clicking videos.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/BeNDYGo/YouTube-Watcher/*"
  ],
  "action": {
    "default_title": "YouTube Watcher",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
